# Core runtime settings
APP_ENV=development
APP_DEBUG=true
WEB_PORT=3000
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# 前端默认走相对路径：
# - `vp dev` 通过 Vite proxy 把 `/api` 转发到本机 API
# - Docker 单机模式由 nginx 把 `/api` 反代到 `api` 服务
# 如果要指向独立后端，只填 origin，例如 `http://localhost:8000`，不要带尾部 `/api`
VITE_API_BASE_URL=

# Local storage roots
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
NORMALIZED_DIR=./data/normalized
SQLITE_PATH=./data/sqlite/ai_qa.db
# Chroma collection data is persisted under this directory.
CHROMA_PATH=./data/chroma

# Bootstrap admin account. Only used when the database has no admin user yet.
INITIAL_ADMIN_USERNAME=admin
# Required only when the database has no admin user yet.
# At least 8 characters, at least 3 of: uppercase, lowercase, digits, special chars.
# Generate one with: python3 -c "import string,secrets; c=string.ascii_letters+string.digits+'!@'; print(''.join(secrets.choice(c) for _ in range(16)))"
INITIAL_ADMIN_PASSWORD=

# Auth runtime settings.
# Refresh token stays in the HttpOnly session cookie; access token is a short-lived PyJWT bearer token.
ACCESS_TOKEN_TTL_MINUTES=15
JWT_ALGORITHM=HS256
# Must be set! At least 32 characters. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
# Optional: force the refresh cookie Secure flag on or off.
# Leave unset to auto-detect from the incoming request scheme.
# SESSION_COOKIE_SECURE=true

# Optional provider bootstrap values.
# These values can be used on first startup to seed provider settings into SQLite.
INITIAL_RESPONSE_PROVIDER=ollama
INITIAL_EMBEDDING_PROVIDER=ollama
INITIAL_VISION_PROVIDER=ollama

INITIAL_OPENAI_API_KEY=
INITIAL_OPENAI_BASE_URL=https://api.openai.com/v1
INITIAL_OPENAI_CHAT_MODEL=gpt-5.4
# Keep chat/vision and embedding defaults separate so the bootstrap config works out of the box.
INITIAL_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
INITIAL_OPENAI_VISION_MODEL=gpt-5.4
INITIAL_PROVIDER_TIMEOUT_SECONDS=60

INITIAL_ANTHROPIC_API_KEY=
INITIAL_ANTHROPIC_BASE_URL=https://api.anthropic.com
INITIAL_ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5
INITIAL_ANTHROPIC_VISION_MODEL=claude-sonnet-4-5

INITIAL_VOYAGE_API_KEY=
INITIAL_VOYAGE_BASE_URL=https://api.voyageai.com/v1
INITIAL_VOYAGE_EMBEDDING_MODEL=voyage-3.5

# 本地 `just dev` 主线默认直连宿主机 Ollama。
# 如果改走 Docker Compose 并且 Ollama 仍跑在宿主机，把这里改成 `http://host.docker.internal:11434`。
INITIAL_OLLAMA_BASE_URL=http://localhost:11434
INITIAL_OLLAMA_CHAT_MODEL=qwen3.5:4b
INITIAL_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
INITIAL_OLLAMA_VISION_MODEL=qwen3.5:4b
